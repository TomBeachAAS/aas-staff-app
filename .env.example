# Supabase — get these from your Supabase project dashboard (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Used for server-side operations (keep secret — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (used for auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: set to 'production' on deployment
NODE_ENV=development
